#compdef init-script.sh init-script
# zsh completion for init-script
# Generated by Shell Script Templates v4 completions plugin
#
# Installation:
#   Copy to a directory in your $fpath, e.g.:
#     cp this-file ~/.zsh/completions/_init-script
#   Then: autoload -Uz compinit && compinit

_init_script() {
    local -a options
    options=(
        '(-h --help)'{-h,--help}'[Show help message and exit]'
        '(-V --version)'{-V,--version}'[Show version information and exit]'
        '(-p --port)'{-p,--port}'[Port an existing v1-v3 script to v4]:script file:_files -g "*.sh *.zsh"'
        '(-o --output)'{-o,--output}'[Output directory]:output directory:_directories'
        '--shell[Pre-select shell type]:shell:(bash zsh)'
        '--name[Pre-set script name]:script name:'
        '(-q --quiet)'{-q,--quiet}'[Minimal output]'
        '--non-interactive[Use all defaults for AI/CI integration]'
    )

    _arguments -s $options '*:file:_files'
}

_init_script "$@"
